# 站点绝对 URL（用于 metadata / Open Graph；生产环境建议配置；未设置时用 VERCEL_URL 或 localhost）
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# 为 true 时需已执行 supabase/migrations 中含 processing_jobs 的 SQL：抓取后入队、处理优先消费 job；URL 导入仅解析入队、不再在请求内跑 AI
PROCESSING_JOBS_ENABLED=false

# 内部 Cron：GET/POST /api/internal/cron/process-jobs?secret=... 或 Header x-cron-secret / Authorization: Bearer
CRON_SECRET=

# TwitterAPI.io API Key
# 获取地址: https://twitterapi.io
TWITTERAPI_IO_KEY=your_twitterapi_io_key_here

# Anthropic API Key (用于AI处理推文内容)
# 获取地址: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 去重配置
# 硬去重配置
HARD_DEDUP_ENABLED=true

# 智能去重配置
SMART_DEDUP_TIME_WINDOW_DAYS=7
SMART_DEDUP_SIMILARITY_THRESHOLD=0.9

# 语义去重配置
SEMANTIC_DEDUP_ENABLED=true
SEMANTIC_DEDUP_TIME_WINDOW_HOURS=48
SEMANTIC_DEDUP_BATCH_SIZE=20
SEMANTIC_DEDUP_SIMILARITY_THRESHOLD=75
SEMANTIC_DEDUP_OVERLAP_SIZE=10

# 综合评分权重配置
SCORE_WEIGHT_AUTHORITY=0.35
SCORE_WEIGHT_IMPORTANCE=0.30
SCORE_WEIGHT_DENSITY=0.25
SCORE_WEIGHT_RECENCY=0.10

# 抓取性能配置
FETCH_CONCURRENT_LIMIT=5          # 并发抓取博主数量
FETCH_BATCH_DELAY_MS=2000         # 批次间延迟（毫秒）
FETCH_USER_INFO_CONCURRENT=5      # 并发更新用户信息数量
FETCH_USER_INFO_DELAY_MS=1000     # 用户信息批次间延迟

# AI 处理性能配置
AI_BATCH_DELAY_MS=500             # AI 批次间延迟（毫秒）
